ols_tau_est = cf["w_train"] +
cf["I(w_train * bp)"]       * x_te_df$bp +
cf["I(w_train * travel)"]   * x_te_df$travel +
cf["I(w_train * digital)"]  * x_te_df$digital +
cf["I(w_train * comorbid)"] * x_te_df$comorbid +
cf["I(w_train * age)"]      * x_te_df$age
} else {
ols_tau_est = rep(NA_real_, n_test)
}
learners_all = list(
rlasso    = rlasso_est,
rboost    = rboost_est,
rkern     = rkern_est,
slasso    = slasso_est,
sboost    = sboost_est,
skern     = skern_est,
tlasso    = tlasso_est,
tboost    = tboost_est,
tkern     = tkern_est,
xlasso    = xlasso_est,
xboost    = xboost_est,
xkern     = xkern_est,
zero_pred = rep(0, n_test),
ols_inter = as.numeric(ols_tau_est)
)
# ----------------------------------------------------------
# EVALUATION
# ----------------------------------------------------------
tau_variance = var(tau_test)
eval_one = function(est, name) {
# Return NAs if learner failed
if (all(is.na(est))) {
return(list(
learner    = name, failed = TRUE,
norm_mse   = NA, rank_corr = NA,
mean_tau   = NA,
est_sg1    = NA, rec_sg1 = NA, sign_sg1 = NA,
est_sg2    = NA, rec_sg2 = NA, sign_sg2 = NA,
est_sg3    = NA, dev_sg3 = NA
))
}
raw_mse  = mean((est - tau_test)^2, na.rm = TRUE)
norm_mse = raw_mse / tau_variance
rank_corr= ifelse(sd(est, na.rm=TRUE) < 1e-10, NA,
cor(est, tau_test, method="spearman",
use="complete.obs"))
est_sg1 = mean(est[sg1], na.rm = TRUE)
est_sg2 = mean(est[sg2], na.rm = TRUE)
est_sg3 = mean(est[sg3], na.rm = TRUE)
list(
learner    = name,
failed     = FALSE,
norm_mse   = round(norm_mse, 6),
rank_corr  = ifelse(is.na(rank_corr), NA, round(rank_corr, 6)),
mean_tau   = round(mean(est, na.rm=TRUE), 6),
est_sg1    = round(est_sg1, 6),
rec_sg1    = round(est_sg1 / true_sg1, 6),
sign_sg1   = sign(est_sg1) == sign(true_sg1),
est_sg2    = round(est_sg2, 6),
rec_sg2    = round(est_sg2 / true_sg2, 6),
sign_sg2   = sign(est_sg2) == sign(true_sg2),
est_sg3    = round(est_sg3, 6),
dev_sg3    = round(abs(est_sg3 - true_sg3), 6)
)
}
eval_results = mapply(eval_one, learners_all, names(learners_all),
SIMPLIFY = FALSE)
# ----------------------------------------------------------
# RETURN ITERATION RESULTS
# ----------------------------------------------------------
list(
seed        = iter_seed,
skipped     = FALSE,
true_ate    = round(mean(tau_x), 6),
true_ate_test=round(mean(tau_test), 6),
tau_sd      = round(sd(tau_test), 6),
pct_beneficial = round(mean(tau_x < 0), 4),
sg_sizes    = list(sg1=sum(sg1), sg2=sum(sg2), sg3=sum(sg3)),
true_sg1    = round(true_sg1, 6),
true_sg2    = round(true_sg2, 6),
true_sg3    = round(true_sg3, 6),
results     = eval_results
)
}
# ============================================================
# RUN ITERATIONS IN PARALLEL
# ============================================================
cat("Starting parallel simulation...\n")
sim_start = Sys.time()
all_iterations = future_map(
1:n_iter,
function(i) run_one_iteration(
iter_seed  = i,
n          = n,
n_train    = n_train,
n_test     = n_test,
sigma      = sigma,
boost_args = boost_args
),
.options = furrr_options(seed = TRUE),
.progress = TRUE
)
sim_end = Sys.time()
total_time = round(as.numeric(sim_end - sim_start, units = "mins"), 2)
cat("\nAll iterations complete in", total_time, "minutes\n")
# ============================================================
# SUMMARISE ACROSS ITERATIONS
# ============================================================
# Separate completed and skipped iterations
completed  = Filter(function(x) !x$skipped, all_iterations)
skipped    = Filter(function(x)  x$skipped, all_iterations)
n_complete = length(completed)
n_skipped  = length(skipped)
cat("Completed:", n_complete, "| Skipped:", n_skipped, "\n")
x
x$skipped
# ============================================================
# TELEMEDICINE — MULTI-ITERATION PARALLEL SIMULATION
# Runs n_iter independent iterations in parallel
# Each iteration: fresh data generation + all learners + evaluation
# Results stored in a single JSON file
# ============================================================
library(MASS)
library(rlearner)
library(KRLS2)
library(jsonlite)
library(future)
library(furrr)
# ============================================================
# CONFIGURATION
# ============================================================
n_iter   = 5     # number of iterations
n        = 250     # total sample size per iteration
n_train  = 200     # training set size
n_test   = 100      # test set size
sigma    = 5       # noise SD for outcome Y
# Boosting settings — reduced for speed across many iterations
boost_args = list(
num_search_rounds     = 5,
k_folds               = 5,
ntrees_max            = 300,
early_stopping_rounds = 5,
verbose               = FALSE
)
# Parallelisation — use all cores minus one
n_workers = max(1, parallel::detectCores() - 1)
plan(multisession, workers = n_workers)
cat("Running", n_iter, "iterations on", n_workers, "workers\n")
cat("Estimated time: check after first 5 iterations complete\n\n")
# ============================================================
# SINGLE ITERATION FUNCTION
# Takes a seed, generates data, fits all learners,
# evaluates on test set, returns a named list of results
# Self-contained — no global state dependencies
# ============================================================
run_one_iteration = function(iter_seed, n, n_train, n_test,
sigma, boost_args) {
# Load libraries inside worker — required for parallel execution
library(MASS)
library(rlearner)
library(KRLS2)
set.seed(iter_seed)
# ----------------------------------------------------------
# DATA GENERATION
# ----------------------------------------------------------
cor_matrix = matrix(c(
1.00,  0.05, -0.10,  0.35,  0.25,
0.05,  1.00,  0.05,  0.00, -0.05,
-0.10,  0.05,  1.00, -0.20, -0.40,
0.35,  0.00, -0.20,  1.00,  0.45,
0.25, -0.05, -0.40,  0.45,  1.00
), nrow = 5, byrow = TRUE)
z = MASS::mvrnorm(n, mu = rep(0, 5), Sigma = cor_matrix)
x1_bp       = 110 + 80 * pnorm(z[,1])
x2_travel   = 20  + 60 * pnorm(z[,2])
x3_digital  = round(20 * pnorm(z[,3]))
x4_comorbid = round(5  * pnorm(z[,4]))
x5_age      = round(40 + 40 * pnorm(z[,5]))
x = cbind(x1_bp, x2_travel, x3_digital, x4_comorbid, x5_age)
colnames(x) = c("bp_baseline", "travel_time", "digital_prior",
"comorbidities", "age")
# Scaled covariates for propensity and tau
x1_s = as.numeric(scale(x1_bp))
x2_s = as.numeric(scale(x2_travel))
x3_s = as.numeric(scale(x3_digital))
x4_s = as.numeric(scale(x4_comorbid))
x5_s = as.numeric(scale(x5_age))
# Propensity
log_odds_w = -0.5 + 1.5*x2_s + 0.5*x1_s - 0.4*x5_s
propensity = pmax(0.05, pmin(plogis(log_odds_w), 0.95))
w          = rbinom(n, 1, propensity)
# True treatment effect
tau_x = -2.0*x2_s + 2.0*x1_s + 1.5*x4_s - 0.8*x3_s + 0.5*x5_s - 0.7
# Baseline and outcome
b_x = 0.6*x1_bp + 2.5*x4_comorbid + 0.3*x5_age - 1.2*x3_digital + 20
y   = pmax(b_x + (w - propensity)*tau_x + rnorm(n, 0, sigma), 80)
# ----------------------------------------------------------
# TRAIN-TEST SPLIT
# ----------------------------------------------------------
train_idx = sample(1:n, size = n_train, replace = FALSE)
test_idx  = setdiff(1:n, train_idx)
x_train = x[train_idx, ];  x_test  = x[test_idx, ]
w_train = w[train_idx];    w_test  = w[test_idx]
y_train = y[train_idx];    y_test  = y[test_idx]
tau_test = tau_x[test_idx]
# ----------------------------------------------------------
# PRE-SPECIFIED SUBGROUPS ON TEST SET
# ----------------------------------------------------------
x1_t = x_test[, "bp_baseline"]
x2_t = x_test[, "travel_time"]
x3_t = x_test[, "digital_prior"]
x4_t = x_test[, "comorbidities"]
x5_t = x_test[, "age"]
# Inside run_one_iteration, replace the subgroup definitions with:
sg1 = x5_t < 58  &    # relaxed from 55 to 58
x2_t > 40  &    # relaxed from 45 to 40
x3_t > 4        # relaxed from 5 to 4
sg2 = x1_t > 155 &    # relaxed from 160 to 155
x4_t > 1        # relaxed from 2 to 1
# now means 2+ comorbidities
# which is clinically still meaningful
sg3 = x5_t > 65  &    # relaxed from 70 to 65
x3_t < 3        # relaxed from 2 to 3
# Skip iteration if any subgroup is too small
if (sum(sg1) < 3 | sum(sg2) < 3 | sum(sg3) < 3) {
return(list(
seed    = iter_seed,
skipped = TRUE,
reason  = paste0("Subgroup too small: SG1=", sum(sg1),
" SG2=", sum(sg2), " SG3=", sum(sg3))
))
}
true_sg1 = mean(tau_test[sg1])
true_sg2 = mean(tau_test[sg2])
true_sg3 = mean(tau_test[sg3])
# ----------------------------------------------------------
# FIT ALL LEARNERS
# Wrapped in tryCatch so one failed learner does not
# abort the entire iteration
# ----------------------------------------------------------
safe_fit = function(fit_fn, pred_fn, ...) {
tryCatch({
fit = fit_fn(...)
pred_fn(fit, x_test)
}, error = function(e) {
rep(NA_real_, n_test)
})
}
rlasso_est = safe_fit(rlasso, predict, x_train, w_train, y_train)
rboost_est = safe_fit(
function(...) do.call(rboost, c(list(...), boost_args)),
predict, x_train, w_train, y_train)
rkern_est  = safe_fit(rkern,  predict, x_train, w_train, y_train)
slasso_est = safe_fit(slasso, predict, x_train, w_train, y_train)
sboost_est = safe_fit(
function(...) do.call(sboost, c(list(...), boost_args)),
predict, x_train, w_train, y_train)
skern_est  = safe_fit(skern,  predict, x_train, w_train, y_train)
tlasso_est = safe_fit(tlasso, predict, x_train, w_train, y_train)
tboost_est = safe_fit(
function(...) do.call(tboost, c(list(...), boost_args)),
predict, x_train, w_train, y_train)
tkern_est  = safe_fit(tkern,  predict, x_train, w_train, y_train)
xlasso_est = safe_fit(xlasso, predict, x_train, w_train, y_train)
xboost_est = safe_fit(
function(...) do.call(xboost, c(list(...), boost_args)),
predict, x_train, w_train, y_train)
xkern_est  = safe_fit(xkern,  predict, x_train, w_train, y_train)
# OLS with interactions
x_tr_df = as.data.frame(x_train)
x_te_df = as.data.frame(x_test)
colnames(x_tr_df) = colnames(x_te_df) = c("bp","travel","digital","comorbid","age")
ols_fit = tryCatch({
lm(y_train ~ bp + travel + digital + comorbid + age +
w_train +
I(w_train * bp) + I(w_train * travel) +
I(w_train * digital) + I(w_train * comorbid) +
I(w_train * age),
data = cbind(x_tr_df, y_train, w_train))
}, error = function(e) NULL)
if (!is.null(ols_fit)) {
cf = coef(ols_fit)
ols_tau_est = cf["w_train"] +
cf["I(w_train * bp)"]       * x_te_df$bp +
cf["I(w_train * travel)"]   * x_te_df$travel +
cf["I(w_train * digital)"]  * x_te_df$digital +
cf["I(w_train * comorbid)"] * x_te_df$comorbid +
cf["I(w_train * age)"]      * x_te_df$age
} else {
ols_tau_est = rep(NA_real_, n_test)
}
learners_all = list(
rlasso    = rlasso_est,
rboost    = rboost_est,
rkern     = rkern_est,
slasso    = slasso_est,
sboost    = sboost_est,
skern     = skern_est,
tlasso    = tlasso_est,
tboost    = tboost_est,
tkern     = tkern_est,
xlasso    = xlasso_est,
xboost    = xboost_est,
xkern     = xkern_est,
zero_pred = rep(0, n_test),
ols_inter = as.numeric(ols_tau_est)
)
# ----------------------------------------------------------
# EVALUATION
# ----------------------------------------------------------
tau_variance = var(tau_test)
eval_one = function(est, name) {
# Return NAs if learner failed
if (all(is.na(est))) {
return(list(
learner    = name, failed = TRUE,
norm_mse   = NA, rank_corr = NA,
mean_tau   = NA,
est_sg1    = NA, rec_sg1 = NA, sign_sg1 = NA,
est_sg2    = NA, rec_sg2 = NA, sign_sg2 = NA,
est_sg3    = NA, dev_sg3 = NA
))
}
raw_mse  = mean((est - tau_test)^2, na.rm = TRUE)
norm_mse = raw_mse / tau_variance
rank_corr= ifelse(sd(est, na.rm=TRUE) < 1e-10, NA,
cor(est, tau_test, method="spearman",
use="complete.obs"))
est_sg1 = mean(est[sg1], na.rm = TRUE)
est_sg2 = mean(est[sg2], na.rm = TRUE)
est_sg3 = mean(est[sg3], na.rm = TRUE)
list(
learner    = name,
failed     = FALSE,
norm_mse   = round(norm_mse, 6),
rank_corr  = ifelse(is.na(rank_corr), NA, round(rank_corr, 6)),
mean_tau   = round(mean(est, na.rm=TRUE), 6),
est_sg1    = round(est_sg1, 6),
rec_sg1    = round(est_sg1 / true_sg1, 6),
sign_sg1   = sign(est_sg1) == sign(true_sg1),
est_sg2    = round(est_sg2, 6),
rec_sg2    = round(est_sg2 / true_sg2, 6),
sign_sg2   = sign(est_sg2) == sign(true_sg2),
est_sg3    = round(est_sg3, 6),
dev_sg3    = round(abs(est_sg3 - true_sg3), 6)
)
}
eval_results = mapply(eval_one, learners_all, names(learners_all),
SIMPLIFY = FALSE)
# ----------------------------------------------------------
# RETURN ITERATION RESULTS
# ----------------------------------------------------------
list(
seed        = iter_seed,
skipped     = FALSE,
true_ate    = round(mean(tau_x), 6),
true_ate_test=round(mean(tau_test), 6),
tau_sd      = round(sd(tau_test), 6),
pct_beneficial = round(mean(tau_x < 0), 4),
sg_sizes    = list(sg1=sum(sg1), sg2=sum(sg2), sg3=sum(sg3)),
true_sg1    = round(true_sg1, 6),
true_sg2    = round(true_sg2, 6),
true_sg3    = round(true_sg3, 6),
results     = eval_results
)
}
# ============================================================
# RUN ITERATIONS IN PARALLEL
# ============================================================
cat("Starting parallel simulation...\n")
sim_start = Sys.time()
all_iterations = future_map(
1:n_iter,
function(i) run_one_iteration(
iter_seed  = i,
n          = n,
n_train    = n_train,
n_test     = n_test,
sigma      = sigma,
boost_args = boost_args
),
.options = furrr_options(seed = TRUE),
.progress = TRUE
)
sim_end = Sys.time()
total_time = round(as.numeric(sim_end - sim_start, units = "mins"), 2)
cat("\nAll iterations complete in", total_time, "minutes\n")
# ============================================================
# SUMMARISE ACROSS ITERATIONS
# ============================================================
# Separate completed and skipped iterations
completed  = Filter(function(x) !x$skipped, all_iterations)
skipped    = Filter(function(x)  x$skipped, all_iterations)
n_complete = length(completed)
n_skipped  = length(skipped)
cat("Completed:", n_complete, "| Skipped:", n_skipped, "\n")
# All learner names
learner_names = c("rlasso","rboost","rkern",
"slasso","sboost","skern",
"tlasso","tboost","tkern",
"xlasso","xboost","xkern",
"zero_pred","ols_inter")
# For each learner, collect metrics across completed iterations
summarise_learner = function(lname) {
norm_mse_vec  = sapply(completed, function(it)
it$results[[lname]]$norm_mse)
rank_corr_vec = sapply(completed, function(it)
it$results[[lname]]$rank_corr)
sign_sg1_vec  = sapply(completed, function(it)
it$results[[lname]]$sign_sg1)
sign_sg2_vec  = sapply(completed, function(it)
it$results[[lname]]$sign_sg2)
rec_sg1_vec   = sapply(completed, function(it)
it$results[[lname]]$rec_sg1)
rec_sg2_vec   = sapply(completed, function(it)
it$results[[lname]]$rec_sg2)
dev_sg3_vec   = sapply(completed, function(it)
it$results[[lname]]$dev_sg3)
failed_vec    = sapply(completed, function(it)
it$results[[lname]]$failed)
n_valid = sum(!failed_vec, na.rm = TRUE)
ci = function(x) {
x = x[!is.na(x)]
if (length(x) < 2) return(list(mean=NA, sd=NA, ci_lo=NA, ci_hi=NA))
m  = mean(x)
s  = sd(x)
se = s / sqrt(length(x))
list(
mean  = round(m, 4),
sd    = round(s, 4),
ci_lo = round(m - 1.96*se, 4),
ci_hi = round(m + 1.96*se, 4)
)
}
list(
learner       = lname,
n_valid       = n_valid,
n_failed      = sum(failed_vec, na.rm=TRUE),
norm_mse      = ci(norm_mse_vec),
rank_corr     = ci(rank_corr_vec),
sign_sg1_rate = round(mean(sign_sg1_vec, na.rm=TRUE), 4),
sign_sg2_rate = round(mean(sign_sg2_vec, na.rm=TRUE), 4),
rec_sg1       = ci(rec_sg1_vec),
rec_sg2       = ci(rec_sg2_vec),
dev_sg3       = ci(dev_sg3_vec)
)
}
summary_by_learner = lapply(learner_names, summarise_learner)
names(summary_by_learner) = learner_names
# True ATE distribution across iterations
true_ate_vec = sapply(completed, function(it) it$true_ate)
true_ate_summary = list(
mean  = round(mean(true_ate_vec), 4),
sd    = round(sd(true_ate_vec),   4),
ci_lo = round(mean(true_ate_vec) - 1.96*sd(true_ate_vec)/sqrt(n_complete), 4),
ci_hi = round(mean(true_ate_vec) + 1.96*sd(true_ate_vec)/sqrt(n_complete), 4),
min   = round(min(true_ate_vec),  4),
max   = round(max(true_ate_vec),  4)
)
# ============================================================
# PRINT SUMMARY TABLE TO CONSOLE
# ============================================================
cat("\n===========================================\n")
cat("MULTI-ITERATION SUMMARY (n_iter =", n_complete, "completed)\n")
cat("===========================================\n\n")
cat(sprintf("True ATE across iterations: mean=%.3f SD=%.3f 95%%CI [%.3f, %.3f]\n\n",
true_ate_summary$mean, true_ate_summary$sd,
true_ate_summary$ci_lo, true_ate_summary$ci_hi))
cat(sprintf("%-12s | %s | %s | %s | %s\n",
"Learner", "NormMSE mean[CI]", "RankCorr mean[CI]",
"SignSG1%", "SignSG2%"))
cat(strrep("-", 80), "\n")
for (nm in learner_names) {
s = summary_by_learner[[nm]]
cat(sprintf("%-12s | %.3f [%.3f,%.3f] | %s | %.0f%% | %.0f%%\n",
nm,
s$norm_mse$mean, s$norm_mse$ci_lo, s$norm_mse$ci_hi,
ifelse(is.na(s$rank_corr$mean), "  NA [NA,  NA]",
sprintf("%.3f [%.3f,%.3f]",
s$rank_corr$mean,
s$rank_corr$ci_lo,
s$rank_corr$ci_hi)),
s$sign_sg1_rate * 100,
s$sign_sg2_rate * 100))
}
# ============================================================
# EXPORT TO JSON
# ============================================================
cat("\n=== EXPORTING TO JSON ===\n")
json_output = list(
simulation_config = list(
study         = "Telemedicine — Hypertension Follow-up",
n_iterations  = n_iter,
n_completed   = n_complete,
n_skipped     = n_skipped,
n_total       = n,
n_train       = n_train,
n_test        = n_test,
sigma         = sigma,
total_time_mins = total_time
),
true_ate_distribution = true_ate_summary,
summary_by_learner = summary_by_learner,
# Full per-iteration results for any downstream analysis
iterations = all_iterations
)
json_path = "telemed_simulation.json"
write(toJSON(json_output, pretty = TRUE, auto_unbox = TRUE), json_path)
json_path = "telemed_simulation.json"
write(toJSON(json_output), json_path)
cat("Results written to:", json_path, "\n")
cat("File size:", round(file.size(json_path) / 1024^2, 2), "MB\n")
