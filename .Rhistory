cat("Pct below 5:    ", round(mean(relaxed_sizes < 5) * 100, 1), "%\n\n")
cat("=== FURTHER RELAXED (age>60 & digital<5) ===\n")
sg3_further = sapply(1:100, function(seed) {
set.seed(seed)
z       = MASS::mvrnorm(300, mu = rep(0,5), Sigma = cor_matrix)
x5_age  = round(40 + 40 * pnorm(z[,5]))
x3_dig  = round(20 * pnorm(z[,3]))
test_idx = setdiff(1:300, sample(1:300, 200))
sum(x5_age[test_idx] > 60 & x3_dig[test_idx] < 5)
})
cat("Mean SG3 size:  ", round(mean(sg3_further), 1), "\n")
cat("Min SG3 size:   ", min(sg3_further), "\n")
cat("Pct below 5:    ", round(mean(sg3_further < 5) * 100, 1), "%\n\n")
# Also check SG1 and SG2 at n=300 to confirm they are fine
cat("=== SG1 and SG2 at correct n=300 ===\n")
sg12_check = sapply(1:100, function(seed) {
set.seed(seed)
z           = MASS::mvrnorm(300, mu = rep(0,5), Sigma = cor_matrix)
x1_bp       = 110 + 80 * pnorm(z[,1])
x2_travel   = 20  + 60 * pnorm(z[,2])
x3_dig      = round(20 * pnorm(z[,3]))
x4_comorbid = round(5  * pnorm(z[,4]))
x5_age      = round(40 + 40 * pnorm(z[,5]))
test_idx    = setdiff(1:300, sample(1:300, 200))
sg1 = sum(x5_age[test_idx] < 58  &
x2_travel[test_idx] > 40 &
x3_dig[test_idx] > 4)
sg2 = sum(x1_bp[test_idx]      > 155 &
x4_comorbid[test_idx] > 1)
sg3 = sum(x5_age[test_idx]>65 &
x3_dig<3)
c(sg1 = sg1, sg2 = sg2, sg3=sg3)
})
cat("SG1 — mean:", round(mean(sg12_check["sg1",]), 1),
"| min:", min(sg12_check["sg1",]),
"| pct below 5:", round(mean(sg12_check["sg1",] < 5)*100, 1), "%\n")
cat("SG2 — mean:", round(mean(sg12_check["sg2",]), 1),
"| min:", min(sg12_check["sg2",]),
"| pct below 5:", round(mean(sg12_check["sg2",] < 5)*100, 1), "%\n")
cat("SG2 — mean:", round(mean(sg12_check["sg3",]), 1),
"| min:", min(sg12_check["sg3",]),
"| pct below 5:", round(mean(sg12_check["sg3",] < 5)*100, 1), "%\n")
sg3_sizes_relaxed = sapply(1:100, function(seed) {
set.seed(seed)
# CORRECTED: n must equal n_train + n_test = 200 + 100 = 300
n = 300
z        = MASS::mvrnorm(n, mu = rep(0, 5), Sigma = cor_matrix)
x5_age   = round(40 + 40 * pnorm(z[,5]))
x3_dig   = round(20 * pnorm(z[,3]))
# Correct split: 200 train, 100 test
test_idx = setdiff(1:n, sample(1:n, 200))
# Check both original and relaxed thresholds for comparison
sg3_original = sum(x5_age[test_idx] > 70 & x3_dig[test_idx] < 2)
sg3_relaxed  = sum(x5_age[test_idx] > 65 & x3_dig[test_idx] < 3)
c(original = sg3_original, relaxed = sg3_relaxed)
})
# sg3_sizes_relaxed is now a 2 x 100 matrix
original_sizes = sg3_sizes_relaxed["original", ]
relaxed_sizes  = sg3_sizes_relaxed["relaxed",  ]
cat("=== ORIGINAL THRESHOLD (age>70 & digital<2) ===\n")
cat("Mean SG3 size:  ", round(mean(original_sizes), 1), "\n")
cat("Min SG3 size:   ", min(original_sizes), "\n")
cat("Pct below 5:    ", round(mean(original_sizes < 5) * 100, 1), "%\n\n")
cat("=== RELAXED THRESHOLD (age>65 & digital<3) ===\n")
cat("Mean SG3 size:  ", round(mean(relaxed_sizes), 1), "\n")
cat("Min SG3 size:   ", min(relaxed_sizes), "\n")
cat("Pct below 5:    ", round(mean(relaxed_sizes < 5) * 100, 1), "%\n\n")
cat("=== FURTHER RELAXED (age>60 & digital<5) ===\n")
sg3_further = sapply(1:100, function(seed) {
set.seed(seed)
z       = MASS::mvrnorm(300, mu = rep(0,5), Sigma = cor_matrix)
x5_age  = round(40 + 40 * pnorm(z[,5]))
x3_dig  = round(20 * pnorm(z[,3]))
test_idx = setdiff(1:300, sample(1:300, 200))
sum(x5_age[test_idx] > 60 & x3_dig[test_idx] < 5)
})
cat("Mean SG3 size:  ", round(mean(sg3_further), 1), "\n")
cat("Min SG3 size:   ", min(sg3_further), "\n")
cat("Pct below 5:    ", round(mean(sg3_further < 5) * 100, 1), "%\n\n")
